# Olive Branch Network frontend environment template
# Copy this file to .env.local. Values prefixed NEXT_PUBLIC_ are embedded in
# browser bundles and must never contain secrets.

# Required: public browser configuration
NEXT_PUBLIC_CHAIN_ID=8453
NEXT_PUBLIC_RPC_URL=https://base-mainnet.example.invalid/v2/replace-me
NEXT_PUBLIC_OBN_TOKEN=0x0000000000000000000000000000000000000001
NEXT_PUBLIC_STAKING_CONTRACT=0x0000000000000000000000000000000000000002
NEXT_PUBLIC_LENS_CONTRACT=0x0000000000000000000000000000000000000003
NEXT_PUBLIC_GOVERNANCE_CONTRACT=0x0000000000000000000000000000000000000004
NEXT_PUBLIC_OLIVE_NFT=0x0000000000000000000000000000000000000005
NEXT_PUBLIC_WC_PROJECT_ID=replace-with-walletconnect-project-id
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Server-only configuration required by specific features
# Prefer these server-only RPC variables for API routes so credentials are not
# exposed in browser bundles.
RPC_URL=https://base-mainnet.example.invalid/v2/replace-me
BASE_RPC_URL=https://base-mainnet.example.invalid/v2/replace-me
TOKEN_ADDRESS=0x0000000000000000000000000000000000000001
DUNE_API_KEY=replace-with-dune-api-key
CDP_API_KEY_NAME=organizations/example/apiKeys/example
CDP_API_KEY_PRIVATE_KEY=replace-with-cdp-private-key

# Optional: public browser configuration. These identifiers are designed to
# be visible to users; apply origin and quota restrictions at each provider.
NEXT_PUBLIC_CDP_PROJECT_ID=replace-with-cdp-project-id
NEXT_PUBLIC_ONCHAINKIT_API_KEY=replace-with-public-onchainkit-key
NEXT_PUBLIC_PAYMASTER_URL=https://paymaster.example.invalid
NEXT_PUBLIC_CAST_SHARE_URL=https://example.invalid/share
NEXT_PUBLIC_NEXT_VOTE_DATE=2027-01-01T00:00:00Z
NEXT_PUBLIC_ENABLE_MINIKIT=0

# Optional: server-only configuration
BASE_RPC_URL_ALT=https://base-mainnet-backup.example.invalid/v2/replace-me
NON_CIRC_ADDRESSES=0x0000000000000000000000000000000000000007
BASE_DASHBOARD_API_KEY=replace-with-base-dashboard-api-key
BASE_APP_URL=https://example.invalid
NEYNAR_API_KEY=replace-with-neynar-api-key
# Required only when the privileged notification broadcast endpoint is used.
NOTIFICATION_API_KEY=generate-a-long-random-secret

# Optional: local tooling
PORT=3000
NEXT_DIST_DIR=.next
